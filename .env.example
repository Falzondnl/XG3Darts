# ============================================================
# XG3 Darts — Environment Variables
# Copy to .env and fill in all required values.
# NEVER commit the .env file to version control.
# ============================================================

# ---- Service ----
SERVICE_NAME=xg3-darts
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- Optic Odds ----
OPTIC_ODDS_API_KEY=bee1a131-9b09-44bf-8fa8-76cbef0a18a8
OPTIC_ODDS_HTTP_PASSWORD=MIO0FIM33DDMDZJB
OPTIC_ODDS_RABBITMQ_USER=6IAP5GU1_8
OPTIC_ODDS_RABBITMQ_PASS=OVG7T525BIVK43DL
OPTIC_ODDS_RABBITMQ_HOST=copilot-rmq.opticodds.com

# ---- DartConnect ----
DARTCONNECT_API_KEY=
DARTCONNECT_BASE_URL=https://api.dartconnect.com

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/xg3darts
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=300

# ---- Service URL ----
DARTS_SERVICE_URL=http://localhost:8000/api/v1/darts

# ---- GDPR ----
# REQUIRED in production — set to a long random secret
GDPR_PSEUDONYM_SECRET=

# ---- Data ----
DATA_ROOT=D:/codex/Data/Darts

# ---- Feature Flags ----
ENABLE_LIVE_PRICING=false
ENABLE_GPU_SIMULATION=false
